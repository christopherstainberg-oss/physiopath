{
  "name": "physiopath",
  "version": "1.0.0",
  "private": true,
  "description": "PhysioPath — personalized, contraindication-aware injury recovery programs (MSK, neuro, cardiac, pulmonary) as an installable PWA.",
  "type": "module",
  "engines": { "node": ">=22" },
  "scripts": {
    "gen:conditions": "node scripts/generate-conditions.mjs",
    "gen:exercises": "node scripts/generate-exercises.mjs",
    "gen:medications": "node scripts/generate-medications.mjs",
    "gen:icons": "node scripts/generate-icons.mjs",
    "assemble": "node scripts/assemble-app.mjs",
    "build": "node scripts/build.mjs",
    "serve": "node scripts/assemble-app.mjs && node scripts/serve.mjs",
    "dev": "node scripts/assemble-app.mjs && node scripts/serve.mjs",
    "test": "node test/index.mjs",
    "test:smoke": "node test/smoke.mjs"
  },
  "license": "MIT"
}
